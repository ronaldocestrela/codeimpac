{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CodeImpactDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Issuer": "CodeImpact",
    "Audience": "CodeImpactUsers",
    "Secret": "ReplaceThisWithASecretKeyOfAtLeast32Chars",
    "AccessTokenExpirationMinutes": 30,
    "RefreshTokenExpirationDays": 30
  },
  "GitHub": {
    "ClientId": "YourGitHubClientId",
    "ClientSecret": "YourGitHubClientSecret",
    "RedirectUri": "https://localhost:1597/github/callback",
    "Scope": "read:user repo"
  },
  "OpenAI": {
    "BaseUrl": "https://api.openai.com/v1",
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "Temperature": 0.2,
    "MaxTokens": 1200,
    "MaxRetries": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
